load "io";
load "stdtent";
load "bsearch.tent";

io.println("please enter numbers in sorted order");
in_vec = [];
cur = io.input("enter number: ");
while cur != "end" {
	v = int.parse(cur);
	if !stdtent.isErr(v) {
		in_vec.push(v);
	} else {
		io.println("invalid integer");
	}
	cur = io.input("enter number: ");
}
target = int.parse(io.input("target number: "));
res = bsearch(in_vec, target);
if res == -1 {
	io.println("target value ", target, " not found");
} else {
	io.println("found target value ", target, " at index ", res);
}
